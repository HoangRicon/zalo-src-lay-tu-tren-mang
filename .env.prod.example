# ── Zalo CRM — Production Environment Variables ────────────────────────────────
# Copy this file to .env before running:
#   cp .env.prod.example .env
# Then fill in all values below.

# ── Application ──────────────────────────────────────────────────────────────
APP_URL=https://your-domain.com        # Public URL of your VPS (change this!)
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=crmuser
DB_PASSWORD=change_me_strong_password   # ⚠️ Replace with a strong random password
DB_NAME=zalocrm

# PostgreSQL connection string (auto-set in docker-compose.prod.yml via this file)
DATABASE_URL=postgresql://crmuser:change_me_strong_password@db:5432/zalocrm?schema=public

# ── Authentication ───────────────────────────────────────────────────────────
# ⚠️ Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl

# ── Zalo OA Credentials (from https://developers.zalo.me) ───────────────────
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret
